{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-G",
                "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_CXX_COMPILER=D:/mingw64/bin/g++.exe"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMake: Build All",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build"
            ],
            "dependsOn": "CMake: Configure",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "CMake: Build Active File Target",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "${relativeFileDirname}_${fileBasenameNoExtension}"
            ],
            "dependsOn": "CMake: Configure",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Run: Active File Executable (No Build)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "chcp 65001>nul && \"${workspaceFolder}\\build\\bin\\${relativeFileDirname}\\${relativeFileDirname}_${fileBasenameNoExtension}.exe\""
            ],
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Target",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "${input:targetName}"
            ],
            "dependsOn": "CMake: Configure",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ],
    "inputs": [
        {
            "id": "targetName",
            "type": "promptString",
            "description": "Input CMake target name, e.g. chapter_tree_binary_tree"
        }
    ]
}
