{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Active CPP",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/${relativeFileDirname}/${relativeFileDirname}_${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "D:/mingw64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: Build Active File Target"
        },
        {
            "name": "Run Active CPP (No Build)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/${relativeFileDirname}/${relativeFileDirname}_${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "D:/mingw64/bin/gdb.exe",
            "noDebug": true
        }
    ]
}
